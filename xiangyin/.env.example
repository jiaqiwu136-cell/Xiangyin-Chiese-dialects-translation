# ============================================================
# 乡音 XIANG·YIN · 方言 ↔ 英语 翻译平台 - 大模型 API 配置
# ============================================================
# 本文件为环境变量模板。
# 操作流程：
#   1. 复制本文件为 .env（与 app.py 同目录）
#   2. 至少填入任意一家大模型服务商的 API Key（保留示例名，或新增 NAME）
#   3. 启动 .venv\\Scripts\\python.exe app.py
#   4. ✅ 观察控制台打印 "=== LLM Provider 配置 ==="，确认服务商/模型已加载；
#        若显示 "⚠ 当前未配置任何大模型服务商"，请回到本文件核对。
#   5. 访问 http://127.0.0.1:5000/  使用
# ============================================================

# ---- Flask 服务配置 ----
FLASK_ENV=development
FLASK_PORT=5000
SECRET_KEY=change-me-in-production-please

# ============================================================
# LLM 服务商及模型池配置（多服务商可同时配置）
# 每个服务商 {NAME} 支持如下 5 个环境变量（全大写，任意 NAME）：
#   {NAME}_PROVIDER     : 接入类型，目前统一填 openai-compatible
#   {NAME}_API_KEY      : 您的 API Key（必填）
#   {NAME}_BASE_URL     : Chat Completions 兼容接口的 /v1 之前的基地址
#   {NAME}_MODELS       : 该服务商启用的模型名，英文逗号分隔（前端下拉可见）
#   {NAME}_DEFAULT_MODEL: 未手动选择时，该服务商默认使用的模型（必须已在 _MODELS 中）
# ============================================================
# 系统会把所有 {NAME} 汇总成模型池，前端下拉框可见；
# 前端选择并回传的 model_id 格式为：{NAME}/{model_name}
# 例如：DASHSCOPE/qwen-plus
# ============================================================

# ---- 示例1：阿里 通义千问 DashScope （推荐，国内稳定） ----
# 控制台申请 Key: https://dashscope.console.aliyun.com/
# 兼容模式 Base URL 固定
DASHSCOPE_PROVIDER=openai-compatible
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODELS=qwen-turbo,qwen-plus,qwen-max,qwen3-max
DASHSCOPE_DEFAULT_MODEL=qwen-plus

# ---- 示例2：百度 文心一言 Qianfan ----
# 控制台申请 Key: https://console.bce.baidu.com/qianfan
WENXIN_PROVIDER=openai-compatible
WENXIN_API_KEY=your-wenxin-api-key-here
WENXIN_BASE_URL=https://qianfan.baidubce.com/v2
WENXIN_MODELS=ernie-4.0-8k,ernie-3.5-128k,ernie-lite-8k
WENXIN_DEFAULT_MODEL=ernie-3.5-128k

# ---- 示例3：智谱 AI (GLM-4 系列) ----
# 控制台申请 Key: https://open.bigmodel.cn/
ZHIPU_PROVIDER=openai-compatible
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODELS=glm-4-flash,glm-4,glm-4-plus,glm-4-0520
ZHIPU_DEFAULT_MODEL=glm-4-flash

# ---- 示例4：DeepSeek（性价比高，推理能力强） ----
# 控制台申请 Key: https://platform.deepseek.com/
DEEPSEEK_PROVIDER=openai-compatible
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# ---- 示例5：通用 OpenAI Compatible（任意兼容 /api/v1/chat/completions 的服务） ----
OPENAI_PROVIDER=openai-compatible
OPENAI_API_KEY=your-openai-compatible-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODELS=gpt-4o-mini,gpt-4o
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ---- 系统默认使用哪家服务商（必须是上方配置过的 NAME，全大写） ----
DEFAULT_PROVIDER=DASHSCOPE

# ============================================================
# 四类专用 LLM 的温度与参数配置（可选，未填则使用默认值）
# ============================================================

# 1) 归属地推理 LLM：温度越低越准确
ORIGIN_TEMPERATURE=0.1

# 2) 方言 → 英语 三版本 温度配置（逗号分隔 3 个 float，对应三卡片的 label）
TRANSLATE_TEMPERATURES=0.3,0.7,1.2

# 3) 英语 → 方言 注音 LLM：中低温度
ZHUYIN_TEMPERATURE=0.4

# 4) 风土科普 LLM：中高温度，追求生动
CULTURE_TEMPERATURE=0.8

# ============================================================
# IP 地理位置解析（可选，免费，失败降级为"来自 未知地区 的用户"）
# 模板：URL 中用 {ip} 占位，表示客户端 IP
# ============================================================
IP_GEO_SERVICE=https://ipapi.co/{ip}/json/
# IP_GEO_SERVICE=https://ip-api.com/json/{ip}?lang=zh-CN

# ---- SQLite 数据库文件路径（相对路径即项目目录下） ----
DATABASE_URL=sqlite:///xiangyin.db

